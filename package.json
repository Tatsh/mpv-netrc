{
  "contributors": ["Andrew Udvare <audvare@gmail.com>"],
  "cspell": {
    "cache": {
      "useCache": true
    },
    "dictionaryDefinitions": [
      {
        "name": "main",
        "path": ".vscode/dictionary.txt"
      }
    ],
    "enableFileTypes": {
      "*": true
    },
    "enableGlobDot": true,
    "files": ["**"],
    "ignorePaths": [
      "*.1",
      "*.har",
      "*.lock",
      ".git/**",
      ".yarn/**/*.cjs",
      ".vscode/extensions.json",
      "dist/**",
      "man/**"
    ],
    "language": "en-GB",
    "languageSettings": [
      {
        "dictionaries": ["main"],
        "languageId": "*"
      }
    ],
    "useGitignore": true
  },
  "description": "A Lua plugin for mpv that uses .netrc files to authenticate media URIs.",
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "cspell": "^9.8.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.3",
    "prettier-plugin-ini": "^1.3.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "prettier-plugin-toml": "^2.0.6"
  },
  "files": ["LICENSE.txt", "README.md"],
  "homepage": "https://tatsh.github.io/mpv-netrc/",
  "keywords": ["lua", "mpv", "mpv-script", "netrc"],
  "license": "MIT",
  "markdownlint-cli2": {
    "config": {
      "MD024": {
        "siblings_only": true
      },
      "MD033": {
        "allowed_elements": ["kbd"]
      },
      "default": true,
      "line-length": {
        "code_blocks": false,
        "line_length": 100,
        "tables": false
      }
    },
    "gitignore": true,
    "globs": ["**/*.md", "**/*.mdc"],
    "noBanner": true,
    "showFound": true
  },
  "name": "mpv-netrc",
  "packageManager": "yarn@4.14.1",
  "prettier": {
    "endOfLine": "lf",
    "iniSpaceAroundEquals": true,
    "jsonRecursiveSort": true,
    "overrides": [
      {
        "files": ["*.json.dist", "package.json"],
        "options": {
          "parser": "json"
        }
      }
    ],
    "plugins": [
      "@prettier/plugin-xml",
      "prettier-plugin-ini",
      "prettier-plugin-sort-json",
      "prettier-plugin-toml"
    ],
    "printWidth": 100,
    "reorderKeys": true,
    "singleQuote": true
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:Tatsh/mpv-netrc.git"
  },
  "scripts": {
    "check-formatting": "prettier --check . && markdownlint-cli2 --config package.json --configPointer /markdownlint-cli2",
    "check-spelling": "cspell --no-progress",
    "dict:update": "rm -f .vscode/dictionary.txt && cspell lint --no-progress --no-summary --unique --words-only | tr '[:upper:]' '[:lower:]' | sort -u > .vscode/dictionary.txt",
    "format": "prettier --write . && markdownlint-cli2 --config package.json --configPointer /markdownlint-cli2 --fix",
    "gen-manpage": "pandoc --standalone --to man -o man/mpv-netrc.7",
    "qa": "yarn check-spelling && yarn check-formatting",
    "test": "busted -o utfTerminal",
    "test:cov": "yarn test && luacov"
  },
  "version": "0.0.2"
}
